    },
    {
      "cell_type": "code",
      "source": [
        "# WATERFALL CHART\n",
        "\n",
        "df_predictions = linker.inference.predict()\n",
        "records_to_view = df_predictions.as_pandas_dataframe().sample(3).to_dict(orient='records')\n",
        "linker.visualisations.waterfall_chart(records_to_view, filter_nulls=False)\n",
        "\n",
        "\n",
        "# While the match weights chart summarises the whole model,\n",
        "# the waterfall chart shows how the final match score is calculated for ONE specific pair of records.\n",
        "# Each bar shows how much a single variable pushed the score up or down for that pair.\n",
        "# It starts with the prior (lambda) as the baseline,\n",
        "# then adds or subtracts evidence from each comparison — name, DOB, county, etc.\n",
        "# Very useful for spot checking individual matches and understanding why two records were or were not linked.\n"
      ],
